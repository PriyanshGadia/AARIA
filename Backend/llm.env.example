# AARIA LLM Configuration
# Copy this file to llm.env and fill in your API keys
# IMPORTANT: Never commit llm.env to version control

# Local LLM (Ollama) - Recommended for privacy
# Install: curl https://ollama.ai/install.sh | sh
# Pull model: ollama pull llama3.2
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Gemini (FREE tier available)
# Get your API key from: https://makersuite.google.com/app/apikey
# Note: Use gemini-1.5-flash or gemini-1.5-pro (gemini-pro is deprecated)
GEMINI_API_KEY=

# Groq (Ultra-fast, low cost)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=

# OpenAI (GPT-3.5-turbo, GPT-4)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default provider to use (local, gemini, groq, openai, anthropic)
DEFAULT_LLM_PROVIDER=local
